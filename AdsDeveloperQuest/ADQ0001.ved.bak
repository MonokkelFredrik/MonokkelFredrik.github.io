			</TextTextLanguages>
		</Text>
		<Text name="Id: 42 - Office: Chair: 'Look_coin' executed" id="42" order="42" lastModified="-1">
			<TextTextLanguages>
				<text Text="Den ser hard ut!" path="assets/speech/hard.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 43 - Office: Chair: 'Talk_coin' executed" id="43" order="43" lastModified="-1">
