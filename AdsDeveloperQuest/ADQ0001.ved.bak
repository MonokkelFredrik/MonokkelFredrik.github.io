		<Text name="Unnamed" id="171" order="171" lastModified="-1">
			<TextTextLanguages>
				<text Text="Ah.. Deilig å endelig være på jobb som &lt;br/&gt;innleid seniorkonsulent i annonseutvikling!&lt;p&gt;&lt;br/&gt;Skulle ønske det var flere på jobb kl 06:00 &lt;br/&gt;da jeg liker å starte&lt;p&gt;&lt;br/&gt;Men ....&lt;br/&gt;jeg får prøve å komme i gang på egenhånd&lt;p&gt;&lt;br/&gt;Dette spillet er laget i faguke med &lt;br/&gt;Visionaire&lt;p&gt;&lt;br/&gt;" path="assets/speech/intro.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Unnamed" id="193" order="193" lastModified="-1">
			<TextTextLanguages>
				<text Text="Koppen er smekkfull" path="assets/speech/smekkfull.ogg" int="0"/>
