		</Text>
		<Text name="Id: 70 - Kitchen: coffee machine: 'Use_coin' executed" id="70" order="70" lastModified="-1">
			<TextTextLanguages>
				<text Text="Kaffe kaffe kaffe" path="assets/speech/kaffekaffe.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 75 - Office: Mac: 'Use_coin' executed" id="75" order="75" lastModified="-1">
			<TextTextLanguages>
				<text Text="Ahhhhhh&lt;p&gt;Akutt behov for koffein før jeg jobber! Jeg må finne en kaffekopp&lt;p&gt;Jeg får se hva som er på kjøkkenet" path="assets/speech/akutt.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 77 - Bathroom: toilet: 'Look_coin' executed" id="77" order="77" lastModified="-1">
			<TextTextLanguages>
				<text Text="Så pent!" path="assets/speech/pent.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 78 - Bathroom: toilet: 'Talk_coin' executed" id="78" order="78" lastModified="-1">
			<TextTextLanguages>
				<text Text="Lille toalett på gulvet der, hvem er vakrest i landet her?" path="assets/speech/vakrest.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 79 - Bathroom: toilet: 'Use_coin' executed" id="79" order="79" lastModified="-1">
			<TextTextLanguages>
				<text Text="Null balast i tanken" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 80 - Bathroom: toilet: 'Use_coin' executed" id="80" order="80" lastModified="-1">
			<TextTextLanguages>
				<text Text="ahhhhhh....." path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 81 - Bathroom: sink: 'Use_coin' executed" id="81" order="81" lastModified="-1">
			<TextTextLanguages>
				<text Text="lalallallallallalllaalallalallallallal" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 82 - Bathroom: sink: 'Use_coin' executed" id="82" order="82" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg har verdens reneste hender" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 83 - Bathroom: sink: 'Use_coin' executed" id="83" order="83" lastModified="-1">
			<TextTextLanguages>
				<text Text="og de største" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 84 - Kitchen: ads_picture: 'Use_coin' executed" id="84" order="84" lastModified="-1">
			<TextTextLanguages>
				<text Text="Ja hver dag!" path="assets/speech/hverdag.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 85 - Kitchen: ads_picture: 'Talk_coin' executed" id="85" order="85" lastModified="-1">
			<TextTextLanguages>
				<text Text="will you merry me?" path="assets/speech/merry.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 86 - Kitchen: coffee machine: 'Talk_coin' executed" id="86" order="86" lastModified="-1">
			<TextTextLanguages>
				<text Text="Gi meg kaffe!&lt;p&gt;Nå" path="assets/speech/gimegkaffe.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 88 - Kitchen: coffee machine: 'Look_coin' executed" id="88" order="88" lastModified="-1">
			<TextTextLanguages>
				<text Text="Deilig deilig koffein dispenser" path="assets/speech/dispenser.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 89 - Office: Mac: 'Use_coin' executed" id="89" order="89" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg må tømme tanken først" path="assets/speech/tanken.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 90 - Office: Mac: 'Use_coin' executed" id="90" order="90" lastModified="-1">
			<TextTextLanguages>
				<text Text="Hmm, det er bare masse tomme annonseposisjoner her. &lt;p&gt;Hvordan skal jeg få gjort jobben min da?&lt;p&gt;Kanskje det er en bok jeg kan lese?" path="assets/speech/tomme.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 92 - Office: Mac: 'Use_coin' executed" id="92" order="92" lastModified="-1">
			<TextTextLanguages>
				<text Text="Adblock er på ja" path="assets/speech/adblock.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 93 - Office: Mac: 'Use_coin' executed" id="93" order="93" lastModified="-1">
			<TextTextLanguages>
				<text Text="Endelig klar for første dag på jobb!&lt;p&gt;Og jeg har fått en gave av Fredrik Lidal!" path="assets/speech/gave.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 95 - Bathroom: door_to_office: 'Walk' executed" id="95" order="95" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg må vaske henda&lt;p&gt;vask vaske henda&lt;p&gt;vask de henda" path="assets/speech/vaskehenda.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 98 - Office: door_to_toilet: 'Walk' executed" id="98" order="98" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg må sjekke om det er noe jobb på kåmputern først" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 99 - Office: door_to_kitchen: 'Walk' executed" id="99" order="98" lastModified="-1">
			<TextTextLanguages>
