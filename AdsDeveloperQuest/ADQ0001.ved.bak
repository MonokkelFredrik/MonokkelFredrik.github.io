		</Text>
		<Text name="Id: 111 - Office: Book: 'Use_coin' executed" id="111" order="111" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg tar med meg denne jeg" path="assets/speech/tar.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 112 - Office: Book: 'Use_coin' executed" id="112" order="112" lastModified="-1">
			<TextTextLanguages>
				<text Text="Ops, den ramla&lt;p&gt;Hmm, her ser jeg noe interessant&lt;p&gt;" path="assets/speech/ops.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 118 - Office: OpenBook: 'Look_coin' executed" id="118" order="118" lastModified="-1">
			<TextTextLanguages>
				<text Text="AD-BLOCK?!? Det må av!" path="assets/speech/av.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 119 - Office: OpenBook: 'Use_coin' executed" id="119" order="119" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg må komme meg på jobb, jeg har ikke tid til å flytte på denne boka!" path="assets/speech/flytte.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 120 - Office: OpenBook: 'Talk_coin' executed" id="120" order="120" lastModified="-1">
			<TextTextLanguages>
				<text Text="Bla bla bla. ADBLOCK!" path="assets/speech/bla.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 121 - Office: Book: 'Use_coin' executed" id="121" order="121" lastModified="-1">
			<TextTextLanguages>
				<text Text="Det er bare en bok, hva skal jeg med den? Alt jeg trenger ligger på internjet" path="assets/speech/njet.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 122 - Office: Book: 'Look_coin' executed" id="122" order="122" lastModified="-1">
			<TextTextLanguages>
				<text Text="Det var jo noen tomme annonser jeg må bli kvitt" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 124 - Office: Mac: 'Look_coin' executed" id="124" order="124" lastModified="-1">
