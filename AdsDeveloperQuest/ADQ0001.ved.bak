				<text Text="Dass" path="" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 26 - Office: Book: 'Look_coin' executed" id="26" order="25" lastModified="-1">
			<TextTextLanguages>
				<text Text="Annonse 1-0-1&lt;p&gt;Den høres nyttig ut!&lt;p&gt;Kanskje jeg kan bruke den til noe?" path="assets/speech/101.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 28 - Office: Book: 'Talk_coin' executed" id="28" order="25" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg har bedre ting å gjøre en å snakke med en bok&lt;p&gt;&lt;br/&gt;Jeg kan f.eks. prate med meg selv&lt;p&gt;&lt;br/&gt;Eller, jeg kan kanskje jobbe med litt med annonser?&lt;p&gt;" path="assets/speech/jobbeannonser.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 32 - Office: Mac: 'Look_coin' executed" id="32" order="32" lastModified="-1">
			<TextTextLanguages>
				<text Text="Det er en Mac...&lt;p&gt;.... uten annonser" path="assets/speech/mac.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 39 - Office: Mac: 'Talk_coin' executed" id="39" order="39" lastModified="-1">
			<TextTextLanguages>
				<text Text="Jeg er en nerd, men det er grenser!" path="assets/speech/nerd.ogg" int="0"/>
			</TextTextLanguages>
		</Text>
		<Text name="Id: 40 - Office: door_to_kitchen" id="40" order="40" lastModified="-1">
