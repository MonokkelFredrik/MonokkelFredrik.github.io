			</TextTextLanguages>
		</Text>
		<Text name="Id: 69 - Kitchen: coffee machine: 'Use_coin' executed" id="69" order="69" lastModified="-1">
			<TextTextLanguages>
				<text Text="Koppen er allerede smekkfull" path="assets/speech/smekkfull.ogg" int="0"/>
